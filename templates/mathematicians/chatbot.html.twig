{% extends 'base.html.twig' %}
{% block title %}Chatbot IA{% endblock %}
{% block stylesheets %}
    {# 1. On charge le style global (INDISPENSABLE pour le fond sombre et les polices) #}
    <link rel="stylesheet" href="{{ asset('css/mathematicians.css') }}">
    {# 2. On charge le style spécifique au chat #}
    <link rel="stylesheet" href="{{ asset('css/chatbot.css') }}">
{% endblock %}
{% block body %}
    <div class="chatbot-page">
        <div class="header-tag">Assistant IA</div>

        <h1>Assistant Mathématique IA </h1>

        <p class="subtitle">
            Interroge Ezer et explore les solutions mathématiques pas à pas..
        </p>

        <div class="chat-container">

            <div id="messages" class="messages"></div>

            <div class="input-area">
                <input type="text" id="prompt" placeholder="Pose ta question..." autocomplete="off">
                <button onclick="sendMessage()">Envoyer</button>
            </div>

        </div>

    </div>

    <script src="{{ asset('js/chatbot.js') }}"></script>

{% endblock %}
